# Root gitignore for apify project
**/node_modules
**/.DS_Store
**/.env
**/.env.*
!**/.env.example
**/dist
**/build
**/out
**/*.log

# Creator Factory specific ignores
creator-factory/generated-actors/*
!creator-factory/generated-actors/.gitkeep
creator-factory/reports/*
!creator-factory/reports/.gitkeep

# IDE Agent / Swarm Harness ignores
/adaptive-harness/
/agents/
/skills/
/danny-actors/
/generated-icons/
/docs/
/AGENTS.md
/GEMINI.md
creator-factory/scratch/
creator-factory/data/
creator-factory/agents/
creator-factory/AGENTS.md
creator-factory/GEMINI.md
/open-source-push/

